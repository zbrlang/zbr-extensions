{
  "comments": {
    "lineComment": "//"
  },
  "wordPattern": "Z[a-zA-Z0-9_]*|[a-zA-Z0-9_]+",
  "brackets": [],
  "autoClosingPairs": [
    { "open": "{", "close": "}", "notIn": ["string", "comment"] },
    ["\"", "\""],
    ["'", "'"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}\\s*$"
  }
}