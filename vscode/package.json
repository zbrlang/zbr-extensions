{
  "name": "vscode-zbr",
  "displayName": "ZBR Scripting Support",
  "description": "Syntax highlighting and snippets for the ZBR scripting language.",
  "version": "1.0.0",
  "publisher": "zbrlang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zbr",
        "aliases": [
          "ZBR",
          "zbr"
        ],
        "extensions": [
          ".zbr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./images/file-icon.png",
          "dark": "./images/file-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "zbr",
        "scopeName": "source.zbr",
        "path": "./syntaxes/zbr.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zbr",
        "path": "./snippets/snippets.json"
      }
    ]
  }
}
