{
  "grammars": [
    {
      "name": "zbr",
      "camelcase": "Zbr",
      "scope": "source.zbr",
      "path": ".",
      "file-types": [
        "zbr"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^zbr$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "ZBR grammar for tree-sitter",
    "authors": [
      {
        "name": "ZBRLang"
      }
    ],
    "links": {
      "repository": "https://github.com/zbrlang/zbr-extensions"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
