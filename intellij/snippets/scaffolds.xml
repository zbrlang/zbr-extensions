<?xml version="1.0" encoding="UTF-8"?>
<templateSet group="ZBR_Scaffolds">
  <template name="ZBR_Prefix_Scaffold" value="#trigger !${1:command}
#name ${2:Command Name}
#type prefix

ZsendMessage{${3:Hello world}}" description="Scaffold a ZBR prefix command" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="OTHER" value="true" />
    </context>
  </template>
  <template name="ZBR_Slash_Scaffold" value="#trigger /${1:ping}
#name ${2:Ping Command}
#type slash
#scope guild
#description ${3:Slash command}

ZsendMessage{${4:Pong}}" description="Scaffold a ZBR slash command" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="OTHER" value="true" />
    </context>
  </template>
  <template name="ZBR_Sub_slash_Scaffold" value="#trigger /admin ${1:ban}
#name ${2:Admin Subcommand}
#type sub-slash

ZsendMessage{${3:Done}}" description="Scaffold a ZBR sub-slash command" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="OTHER" value="true" />
    </context>
  </template>
  <template name="ZBR_Interaction_Scaffold" value="#trigger onInteraction{${1:id}}
#name ${2:Interaction Handler}
#type interaction

ZsendMessage{${3:Handled}}" description="Scaffold an interaction handler" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="OTHER" value="true" />
    </context>
  </template>
  <template name="ZBR_Event_Scaffold" value="#trigger onMessage
#name ${1:Message Event}
#type event

ZsendMessage{${2:Event triggered}}" description="Scaffold an event handler" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="OTHER" value="true" />
    </context>
  </template>
</templateSet>
