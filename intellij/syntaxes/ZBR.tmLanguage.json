{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ZBR",
  "patterns": [
    {
      "include": "#headers"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#trigger_functions"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#content"
    }
  ],
  "repository": {
    "headers": {
      "patterns": [
        {
          "name": "keyword.control.zbr",
          "match": "^#(name|trigger|description|type|scope|option)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zbr",
          "match": "//.*$"
        }
      ]
    },
    "trigger_functions": {
      "patterns": [
        {
          "name": "entity.name.tag.zbr",
          "match": "\\bonInteraction\\b(?=\\{)|\\bon[a-zA-Z0-9_]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(Z)([a-zA-Z0-9_]+)\\b(?=\\{)",
          "captures": {
            "1": { "name": "keyword.other.zbr" },
            "2": { "name": "entity.name.function.zbr" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.zbr",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.logical.zbr",
          "match": "&&|\\|\\|"
        }
      ]
    },
    "escaped_chars": {
      "patterns": [
        {
          "name": "constant.character.escape.zbr",
          "match": "\\\\\\{|\\\\\\}|\\\\;|\\\\"
        }
      ]
    },
    "content": {
      "patterns": [
        {
          "include": "#functions"
        },
        {
          "include": "#trigger_functions"
        },
        {
          "include": "#escaped_chars"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#braces"
        }
      ]
    },
    "braces": {
      "begin": "(?<!\\\\)\\{",
      "beginCaptures": {
        "0": { "name": "meta.brace.curly.zbr" }
      },
      "end": "(?<!\\\\)\\}",
      "endCaptures": {
        "0": { "name": "meta.brace.curly.zbr" }
      },
      "patterns": [
        {
          "include": "#content"
        },
        {
          "name": "keyword.other.zbr",
          "match": ";"
        }
      ]
    }
  },
  "scopeName": "source.zbr"
}
